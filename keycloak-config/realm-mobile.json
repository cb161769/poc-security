{
  "realm": "mobile-realm",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeout": 1800,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "clients": [
    {
      "clientId": "mobile-app-client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "id.token.signed.response.alg": "RS256",
        "id.token.encrypted.response.alg": "RSA-OAEP",
        "id.token.encrypted.response.enc": "A128GCM",
        "access.token.signed.response.alg": "RS256",
        "access.token.encrypted.response.alg": "RSA-OAEP",
        "access.token.encrypted.response.enc": "A128GCM"
      },
      "webOrigins": ["http://localhost:8100", "http://localhost:4200"],
      "redirectUris": ["http://localhost:8100/*", "http://localhost:4200/*"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "user-api", "description": "Usuario estándar de Odoo" },
      { "name": "admin-api", "description": "Administrador de Odoo" }
    ]
  }
}
